# Konfigurasi Irma Virtual Assistant
APP_NAME=Irma
VERSION=1.0.0

# Voice Settings
VOICE_GENDER=female
VOICE_RATE=175
VOICE_VOLUME=1.0

# Wake Word
WAKE_WORD=hey irma
WAKE_WORD_SENSITIVITY=0.5

# Memory Management
MAX_MEMORY_PERCENT=80
GC_THRESHOLD=50
AUTO_CLEANUP_ENABLED=true

# Security Settings
ZERO_TRUST_MODE=true
AUDIT_LOG_ENABLED=true
MAX_FILE_SIZE_MB=100

# Whitelist Directories (comma separated, relative to user home)
# Contoh: Downloads,Documents\Irma,Desktop\IrmaFiles
WHITELIST_DIRS=Downloads,Documents,Desktop

# Internet Settings
WEB_REQUEST_TIMEOUT=5
MAX_REQUESTS_PER_MINUTE=10
# Tambahkan domain yang diizinkan, dipisahkan dengan koma
ALLOWED_DOMAINS=wikipedia.org,google.com

# Screen Reading
OCR_LANGUAGE=ind+eng
SCREEN_CAPTURE_DELAY=1

# Listening Settings
ENERGY_THRESHOLD=300
PAUSE_THRESHOLD=0.8
PHRASE_TIME_LIMIT=10
AMBIENT_DURATION=1
