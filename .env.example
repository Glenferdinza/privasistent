# Konfigurasi Irma Virtual Assistant
APP_NAME=Irma
VERSION=1.0.0

# Voice Settings
VOICE_GENDER=female
VOICE_RATE=175
VOICE_VOLUME=1.0

# Multi-Language Voice Settings
# 
# === VOSK ENGINE (Fast, Real-time) ===
# AVAILABLE: en (English), ru (Russian) - only these models exist in Vosk
# NOT AVAILABLE: Indonesian & Malay models don't exist in Vosk repository
# WORKAROUND: English model can recognize Indonesian with ~60-70% accuracy
# 
# === WHISPER ENGINE (Accurate, Multi-language) ===
# BEST SOLUTION for Indonesian! OpenAI Whisper is FREE, open source, offline
# Supports: Indonesian, Malay, English, Russian, and 99+ languages
# Accuracy: 85-95% for Indonesian (FAR BETTER than Vosk workaround)
# Trade-off: Slower (2-3s latency) vs Vosk (0.1s real-time)
# 
# Setup Whisper: pip install openai-whisper torch torchaudio
# See WHISPER_SETUP.md for complete guide
# 
# === VOICE ENGINE OPTIONS ===
VOICE_ENGINE=hybrid              # vosk / whisper / hybrid
DEFAULT_VOICE_LANGUAGE=en        # For Vosk: en / ru
DEFAULT_WHISPER_LANGUAGE=id      # For Whisper: id / ms / en / ru / auto
WHISPER_MODEL=small              # tiny(75MB) / base(145MB) / small(488MB) / medium(1.5GB)
WHISPER_DEVICE=cpu               # cpu / cuda (GPU if available)

# Hybrid mode:
# - Fast commands → Vosk (English, real-time)
# - Accurate Indonesian → Whisper (85-95% accuracy, 2-3s latency)
# Voice command: "switch to accurate mode" / "switch to fast mode"

# Wake Word
WAKE_WORD=hey irma
WAKE_WORD_SENSITIVITY=0.5

# Memory Management
MAX_MEMORY_PERCENT=80
GC_THRESHOLD=50
AUTO_CLEANUP_ENABLED=true

# Security Settings
ZERO_TRUST_MODE=true
AUDIT_LOG_ENABLED=true
MAX_FILE_SIZE_MB=100

# Whitelist Directories (comma separated, relative to user home)
# Contoh: Downloads,Documents\Irma,Desktop\IrmaFiles
WHITELIST_DIRS=Downloads,Documents,Desktop

# Internet Settings
WEB_REQUEST_TIMEOUT=5
MAX_REQUESTS_PER_MINUTE=10
# Tambahkan domain yang diizinkan, dipisahkan dengan koma
ALLOWED_DOMAINS=wikipedia.org,google.com

# Screen Reading
# Supported languages: eng (English), ind (Indonesian), msa (Malay), rus (Russian)
# Format: lang1+lang2+lang3 (no spaces)
# Make sure language data files are installed in Tesseract tessdata folder
OCR_LANGUAGE=eng+ind+msa+rus
SCREEN_CAPTURE_DELAY=1

# Listening Settings
ENERGY_THRESHOLD=300
PAUSE_THRESHOLD=0.8
PHRASE_TIME_LIMIT=10
AMBIENT_DURATION=1
